# API
NODE_ENV=development
PORT=4000

# Database (docker service names)
MONGO_URI=mongodb://admin:admin123@mongodb:27017/sprintdock?authSource=admin

# Redis
REDIS_URL=redis://redis:6379

# RabbitMQ
RABBIT_URL=amqp://admin:admin123@rabbitmq:5672

# JWT
JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me-too
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,https://sprintdock-app.vercel.app
OTP_RATE_LIMIT_WINDOW_SEC=60
OTP_RATE_LIMIT_MAX=3

# Internal (worker -> api realtime bridge)
INTERNAL_API_KEY=change-me-internal
API_INTERNAL_URL=http://api:4000/internal/realtime

# Email (stub)
EMAIL_FROM=noreply@sprintdock.local
EMAIL_ENABLED=false

# Frontend (browser talks to host)
VITE_API_URL=http://localhost:4000
VITE_SOCKET_URL=http://localhost:4000

# Production sample (Render + Vercel)
# NODE_ENV=production
# PORT=10000
# MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/sprintdock
# REDIS_URL=rediss://default:<token>@<host>:<port>
# RABBIT_URL=amqps://<user>:<pass>@<host>/<vhost>
# CORS_ORIGINS=https://sprintdock-app.vercel.app
# API_INTERNAL_URL=https://<your-render-api-domain>/internal/realtime
# VITE_API_URL=https://<your-render-api-domain>
# VITE_SOCKET_URL=https://<your-render-api-domain>
